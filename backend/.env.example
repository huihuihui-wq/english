# Shadow Reader configuration template
# 1. Copy this file to backend/.env
# 2. Subtitle generation is now LOCAL and does NOT require an API key.
# 3. Fill in DASHSCOPE_API_KEY only if you want optional cloud features:
#    sentence translation, word pronunciation TTS, AI coach.

# Optional: DashScope key for translation / TTS / AI coach
DASHSCOPE_API_KEY=

# Optional: override defaults
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_COMPATIBLE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TRANSLATE_MODEL=qwen-turbo
MAX_UPLOAD_MB=200

# Translation backend: "dashscope" (cloud, needs key) or "local" (NLLB, fully local).
# Default is "local".
TRANSLATE_BACKEND=local

# Local translation model. NLLB-200 distilled 600M supports 200 languages.
# First use auto-downloads ~600 MB from HuggingFace.
LOCAL_TRANSLATE_MODEL=facebook/nllb-200-distilled-600M

# Local ASR model. Supported: tiny, base, small, medium, large, large-v2, large-v3, etc.
# Default "base" is a good balance of speed and accuracy for English (~150 MB).
WHISPER_MODEL=base

# Optional: YouTube cookie file to bypass bot checks
# YT_COOKIES=./yt_cookies.txt
