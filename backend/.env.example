# Shadow Reader configuration template
# 1. Copy this file to backend/.env
# 2. Fill in your DashScope API key from https://bailian.console.aliyun.com/
#
# Note: You can also set the API key in the web UI (Settings),
# which will be saved to backend/data/settings.json.

# Required
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Optional: override defaults
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# ASR model for text transcription (only qwen3-asr-flash is supported for now)
ASR_MODEL=qwen3-asr-flash
TRANSLATE_MODEL=qwen-plus
MAX_UPLOAD_MB=200
# Audio duration limit per API segment; default is 120 seconds (2 minutes).
# If your account supports longer clips, increase this value.
MAX_ASR_AUDIO_SECONDS=120

# Optional: YouTube cookie file to bypass bot checks
# YT_COOKIES=./yt_cookies.txt
